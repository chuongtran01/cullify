{
  "name": "cullify-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "lint": "npm run lint --prefix apps/web",
    "install:web": "npm install --prefix apps/web",
    "install:image_processor": "python3 -m venv apps/image_processor/.venv && apps/image_processor/.venv/bin/python -m pip install -e apps/image_processor",
    "image_processor": "apps/image_processor/.venv/bin/python -m image_processor.main",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:setup": "docker compose up -d && npm run db:migrate:deploy --prefix apps/web && npm run db:generate --prefix apps/web",
    "db:migrate": "npm run db:migrate --prefix apps/web",
    "db:migrate:deploy": "npm run db:migrate:deploy --prefix apps/web",
    "db:generate": "npm run db:generate --prefix apps/web",
    "db:push": "npm run db:push --prefix apps/web"
  }
}
