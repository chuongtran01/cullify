# Copy to `.env.local` for local development.
# Never commit real secrets — only this example file belongs in git.

# -----------------------------------------------------------------------------
# PostgreSQL (local: docker compose up -d)
# -----------------------------------------------------------------------------
POSTGRES_USER=cullify
POSTGRES_PASSWORD=cullify
POSTGRES_DB=cullify
POSTGRES_PORT=5432

# Prisma / ORM connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://cullify:cullify@localhost:5432/cullify

# -----------------------------------------------------------------------------
# Redis / BullMQ (local: docker compose up -d)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage)
# Create API tokens: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Account ID: Cloudflare Dashboard → R2 → right sidebar
# -----------------------------------------------------------------------------

# Cloudflare account ID (used to build the S3 API endpoint if R2_ENDPOINT is unset)
R2_ACCOUNT_ID=

# R2 API token credentials (S3-compatible access key + secret)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket that stores originals, thumbnails, and derivatives
R2_BUCKET_NAME=

# Optional S3 API endpoint override (default: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
R2_ENDPOINT=

# Region for AWS SDK clients — use `auto` for R2
R2_REGION=auto

# Browser uploads use presigned PUT URLs. Configure bucket CORS in the Cloudflare
# dashboard (R2 → bucket → Settings → CORS policy), e.g.:
#   AllowedOrigins: http://localhost:3000 (and your production origin)
#   AllowedMethods: PUT, GET, HEAD
#   AllowedHeaders: Content-Type
#   ExposeHeaders: ETag
